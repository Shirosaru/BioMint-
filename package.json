{
  "name": "agentic-mint-guard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous mint policy engine MVP with signed attestations",
  "scripts": {
    "demo": "node src/demo.js",
    "demo:keep": "node src/demo.js --keep-state",
    "agent:once": "node src/agent.js --once",
    "agent:once:reset": "node src/agent.js --once --reset",
    "agent:loop": "node src/loop.js",
    "agent:loop:reset": "node src/loop.js --reset",
    "agent:loop:dry": "node src/loop.js --dry-run",
    "agent:loop:full": "USE_WORMHOLE_COLLATERAL=true USE_SWAPS=true node src/loop.js",
    "dashboard": "node src/serve.js",
    "oracle": "node src/oracleAgent.js",
    "mcp": "node src/mcpServer.js",
    "biomint": "ORACLE_FALLBACK=1 node src/demoClinical.js",
    "biomint:keep": "ORACLE_FALLBACK=1 node src/demoClinical.js --keep-state"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@solana/web3.js": "^1.98.4",
    "bs58": "^6.0.0",
    "x402": "^1.2.0"
  }
}
